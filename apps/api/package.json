{
  "name": "@drag-visual/api",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @drag-visual/contracts build",
    "dev": "tsx watch src/main.ts",
    "prebuild": "pnpm --filter @drag-visual/contracts build && pnpm prisma:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "smoke:start": "node scripts/start-smoke.mjs",
    "pretypecheck": "pnpm --filter @drag-visual/contracts build && pnpm prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @drag-visual/contracts build && pnpm prisma:generate",
    "test": "vitest run",
    "prelint": "pnpm --filter @drag-visual/contracts build && pnpm prisma:generate",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "prisma:validate": "prisma validate --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@drag-visual/contracts": "workspace:*",
    "@fastify/static": "~8.3.0",
    "@nestjs/common": "~11.1.11",
    "@nestjs/core": "~11.1.11",
    "@nestjs/platform-fastify": "~11.1.11",
    "@nestjs/swagger": "~11.2.6",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "~5.6.2",
    "pg": "^8.22.0",
    "reflect-metadata": "~0.2.2",
    "rxjs": "~7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "~11.1.11",
    "@types/pg": "^8.20.0",
    "prisma": "7.8.0",
    "tsx": "~4.21.0",
    "typescript": "~6.0.3",
    "vitest": "~4.1.9"
  }
}
