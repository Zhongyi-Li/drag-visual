{
  "name": "drag-visual",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "predev": "pnpm --filter @drag-visual/contracts build",
    "dev": "pnpm --parallel --filter @drag-visual/web --filter @drag-visual/api dev",
    "dev:web": "pnpm --dir apps/web exec vite",
    "dev:mock": "VITE_USE_MOCKS=true pnpm --dir apps/web exec vite",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "pretest": "pnpm --filter @drag-visual/contracts build && pnpm --filter @drag-visual/data-engine build && pnpm --filter @drag-visual/editor-core build && pnpm --filter @drag-visual/component-registry build && pnpm --filter @drag-visual/api prisma:generate",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pretest:watch": "pnpm --filter @drag-visual/contracts build && pnpm --filter @drag-visual/api prisma:generate",
    "test:watch": "vitest",
    "test:api-start": "pnpm --filter @drag-visual/api smoke:start",
    "lint": "pnpm -r lint",
    "lint:openapi": "redocly lint openapi/bi-mvp.yaml"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@redocly/cli": "^2.36.0",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
