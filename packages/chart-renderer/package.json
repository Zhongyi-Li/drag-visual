{
  "name": "@drag-visual/chart-renderer",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @drag-visual/contracts build",
    "build": "tsc -p tsconfig.build.json",
    "pretypecheck": "pnpm --filter @drag-visual/contracts build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @drag-visual/contracts build",
    "test": "vitest run"
  },
  "dependencies": {
    "@drag-visual/contracts": "workspace:*",
    "echarts": "^6.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
